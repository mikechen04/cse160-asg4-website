# twisted prism style model
# has more faces than a simple cube so it looks more "complex"

v 1.000 -1.000 0.000
v 0.707 -1.000 0.707
v 0.000 -1.000 1.000
v -0.707 -1.000 0.707
v -1.000 -1.000 0.000
v -0.707 -1.000 -0.707
v 0.000 -1.000 -1.000
v 0.707 -1.000 -0.707

v 0.707 1.000 0.707
v 0.000 1.000 1.000
v -0.707 1.000 0.707
v -1.000 1.000 0.000
v -0.707 1.000 -0.707
v 0.000 1.000 -1.000
v 0.707 1.000 -0.707
v 1.000 1.000 0.000

v 0.000 -1.300 0.000
v 0.000 1.300 0.000

# side faces (quads, loader triangulates)
f 1 2 10 9
f 2 3 11 10
f 3 4 12 11
f 4 5 13 12
f 5 6 14 13
f 6 7 15 14
f 7 8 16 15
f 8 1 9 16

